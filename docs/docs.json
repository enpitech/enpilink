{
  "$schema": "https://mintlify.com/docs.json",
  "name": "enpilink",
  "theme": "mint",
  "colors": {
    "primary": "#002FFF",
    "light": "#08F5F9",
    "dark": "#002FFF"
  },
  "favicon": {
    "light": "/images/enpilinkFaviconmidnight.svg",
    "dark": "/images/enpilinkFaviconwhite.svg"
  },
  "logo": {
    "light": "/images/enpilinkmidnight.svg",
    "dark": "/images/enpilinkwhite(1).svg"
  },
  "search": {
    "prompt": "Search enpilink docs..."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "home",
              {
                "group": "Fundamentals",
                "icon": "graduation-cap",
                "pages": [
                  "fundamentals",
                  "fundamentals/apps-sdk",
                  "fundamentals/mcp-apps"
                ]
              },
              "quickstart/create-new-app",
              {
                "group": "Add to Existing App",
                "icon": "puzzle-piece",
                "pages": [
                  "quickstart/add-to-existing-app",
                  "quickstart/add-to-existing-app/server",
                  "quickstart/add-to-existing-app/web"
                ]
              },
              "quickstart/migrate",
              "quickstart/test-your-app",
              "quickstart/build-for-production",
              "quickstart/deploy"
            ]
          },
          {
            "group": "Concepts",
            "icon": "lightbulb",
            "pages": [
              "concepts/index",
              "concepts/write-once-run-everywhere",
              "concepts/data-flow",
              "concepts/llm-context-sync",
              "concepts/fast-iteration",
              "concepts/type-safety"
            ]
          },
          {
            "group": "Guides",
            "icon": "book",
            "pages": [
              "guides/fetching-data",
              "guides/managing-state",
              "guides/communicating-with-model",
              "guides/interaction-types",
              "guides/host-environment-context",
              "guides/observability",
              "guides/agent-analytics",
              "guides/configuration",
              "guides/admin",
              "guides/auth",
              "guides/storage"
            ]
          },
          {
            "group": "Console",
            "icon": "display",
            "pages": ["devtools/skills", "devtools/devtools"]
          },
          {
            "group": "Resources",
            "icon": "circle-question",
            "pages": ["faq", "telemetry"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "icon": "house",
            "pages": ["api-reference"]
          },
          {
            "group": "CLI",
            "icon": "terminal",
            "pages": ["api-reference/cli"]
          },
          {
            "group": "Server",
            "icon": "server",
            "pages": ["api-reference/mcp-server", "api-reference/register-tool"]
          },
          {
            "group": "Agent surface",
            "icon": "robot",
            "pages": [
              "api-reference/describe-for-agents",
              "api-reference/get-transport",
              "api-reference/next-middleware"
            ]
          },
          {
            "group": "Hooks",
            "icon": "fishing-rod",
            "pages": [
              "api-reference/use-tool-info",
              "api-reference/use-call-tool",
              "api-reference/use-register-view-tool",
              "api-reference/use-layout",
              "api-reference/use-user",
              "api-reference/use-auth",
              "api-reference/use-display-mode",
              "api-reference/use-open-external",
              "api-reference/use-set-open-in-app-url",
              "api-reference/use-send-follow-up-message",
              "api-reference/use-notify",
              "api-reference/use-intent",
              "api-reference/use-view-state",
              "api-reference/use-request-modal",
              "api-reference/use-request-close",
              "api-reference/use-request-size",
              "api-reference/use-files",
              "api-reference/use-download"
            ]
          },
          {
            "group": "Utilities",
            "icon": "toolbox",
            "pages": [
              "api-reference/create-store",
              "api-reference/generate-helpers",
              "api-reference/data-llm"
            ]
          },
          {
            "group": "Types",
            "icon": "brackets-curly",
            "pages": [
              "api-reference/infer-utility-types",
              "api-reference/file-ref"
            ]
          },
          {
            "group": "Advanced",
            "icon": "gear",
            "pages": [
              "api-reference/use-apps-sdk-context",
              "api-reference/use-mcp-app-context"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "pages": ["examples"]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/enpitech/enpilink"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/enpitech/enpilink"
    }
  },
  "description": "The open, account-free full-stack TS framework for building ChatGPT and MCP Apps",
  "background": {
    "color": {
      "dark": "#051413"
    }
  },
  "fonts": {
    "body": {
      "family": "Inter",
      "weight": 400
    },
    "heading": {
      "family": "Inter",
      "weight": 600
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "enpilink Documentation",
      "og:type": "website"
    }
  },
  "errors": {
    "404": {
      "title": "Oops, well that's awkward..."
    }
  },
  "interaction": {
    "drilldown": false
  }
}
